Package: piglet
Title: Program for Inferring Immunoglobulin Allele Similarity Clusters
        and Genotypes
Version: 1.2.0
Authors@R: c(person("Ayelet", "Peres", role=c("aut","cre"),
                    email="ayelet.peres@yale.edu"),
            person("William", "Lees", role=c("aut"),
